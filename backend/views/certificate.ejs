<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Certificate Of Completion</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Playfair+Display:ital,wght@1,600&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: "Inter", sans-serif;
        background-color: #f4f7f6;
        width: 1122px; /* A4 landscape width at 96 DPI */
        height: 793px; /* A4 landscape height at 96 DPI */
        display: flex;
        justify-content: center;
        align-items: center;
        /* In Puppeteer this body width/height ensures perfect framing */
      }
      .cert-wrapper {
        background-color: #ffffff;
        width: 1060px;
        height: 730px;
        position: relative;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding-left: 140px;
        padding-right: 80px;
      }

      /* Modern Corporate Left Accent Panel */
      .left-accent {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 50px;
        background: linear-gradient(
          180deg,
          #0f172a 0%,
          #1e293b 40%,
          #0ea5e9 100%
        );
      }
      .left-accent-2 {
        position: absolute;
        top: 0;
        left: 50px;
        height: 100%;
        width: 6px;
        background-color: #38bdf8;
      }

      /* Subtle Watermark */
      .watermark {
        position: absolute;
        right: -100px;
        bottom: -80px;
        font-size: 200px;
        font-weight: 800;
        color: #f1f5f9;
        z-index: 0;
        transform: rotate(-10deg);
        pointer-events: none;
        letter-spacing: -5px;
      }

      /* Content Layering */
      .content {
        position: relative;
        z-index: 10;
      }

      .platform-name {
        font-size: 18px;
        font-weight: 800;
        color: #0ea5e9;
        text-transform: uppercase;
        letter-spacing: 4px;
        margin-bottom: 25px;
      }

      .title {
        font-size: 52px;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.1;
        margin-bottom: 40px;
        letter-spacing: -1px;
        width: 600px;
      }

      .subtitle {
        font-size: 16px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 600;
        margin-bottom: 10px;
      }

      .student-name {
        font-family: "Playfair Display", serif;
        font-style: italic;
        font-size: 64px;
        color: #0ea5e9;
        margin-bottom: 30px;
        line-height: 1;
      }

      .description {
        font-size: 16px;
        color: #475569;
        max-width: 600px;
        line-height: 1.6;
        margin-bottom: 10px;
      }

      .course-title {
        font-size: 26px;
        font-weight: 800;
        color: #0f172a;
        max-width: 700px;
        margin-bottom: 60px;
      }

      .footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-top: 40px;
        border-top: 1px solid #e2e8f0;
        padding-top: 30px;
        width: 820px;
      }

      .signature-block {
        display: flex;
        flex-direction: column;
      }

      .signature-line {
        font-family: "Playfair Display", serif;
        font-size: 32px;
        color: #0f172a;
        border-bottom: 2px solid #cbd5e1;
        padding-bottom: 5px;
        margin-bottom: 8px;
        width: 250px;
      }

      .signature-title {
        font-size: 12px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .cert-meta {
        text-align: right;
        font-size: 12px;
        color: #64748b;
        line-height: 1.8;
      }
      .cert-meta span {
        font-weight: 600;
        color: #0f172a;
      }

      .seal {
        position: absolute;
        top: 60px;
        right: 80px;
        width: 100px;
        height: 100px;
        background: #f8fafc;
        border: 4px solid #0ea5e9;
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        box-shadow: 0 10px 20px rgba(14, 165, 233, 0.15);
        z-index: 20;
      }
      .seal-year {
        font-weight: 800;
        font-size: 24px;
        color: #0f172a;
      }
      .seal-text {
        font-size: 10px;
        font-weight: 800;
        color: #0ea5e9;
        text-transform: uppercase;
        letter-spacing: 1px;
      }
    </style>
  </head>
  <body>
    <div class="cert-wrapper">
      <div class="left-accent"></div>
      <div class="left-accent-2"></div>
      <div class="watermark">RDC</div>

      <div class="seal">
        <span class="seal-year"><%= new Date(issueDate).getFullYear() %></span>
        <span class="seal-text">Awarded</span>
      </div>

      <div class="content">
        <div class="platform-name">RDCoders</div>
        <h1 class="title">CERTIFICATE<br />OF COMPLETION</h1>

        <p class="subtitle">This proudly certifies that</p>
        <h2 class="student-name"><%= username %></h2>

        <p class="description">
          Has successfully mastered the curriculum and demonstrated the core
          proficiencies required for:
        </p>
        <h3 class="course-title"><%= courseTitle %></h3>

        <div class="footer">
          <div class="signature-block">
            <div class="signature-line">Ram Dixit</div>
            <div class="signature-title">Lead Instructor, RDCoders</div>
          </div>

          <div class="cert-meta">
            <p>Issue Date: <span><%= issueDate %></span></p>
            <p>Credential ID: <span><%= certificateId %></span></p>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
